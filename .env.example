# ============================================
# VeilleAI - Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://veilleai:veilleai_secret@postgres:5432/veilleai
DB_PASSWORD=veilleai_secret

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# JWT
SECRET_KEY=changeme-super-secret-key-minimum-32-chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
# CORS
FRONTEND_URL=http://localhost:3000

# App
APP_NAME=VeilleAI
DEBUG=true
